// Tourney DB schema
// Multi-tenant por guild_id. Bot + web comparten este schema.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Identity
// ============================================================

model User {
  id           String   @id @default(cuid())
  discordId    String   @unique
  username     String
  globalName   String?
  avatar       String?
  email        String?
  // OAuth tokens (encriptados a nivel app)
  accessToken  String?
  refreshToken String?
  tokenExpires DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participations Participant[]
  ownedTournaments Tournament[]      @relation("TournamentCreator")
  leaderboardEntries LeaderboardEntry[]
  guildMemberships GuildMember[]

  @@index([discordId])
}

model Guild {
  id           String   @id @default(cuid())
  discordId    String   @unique
  name         String
  icon         String?
  ownerId      String?  // Discord user id del owner del server
  // Config del bot en el server
  defaultChannelId   String?
  announcementChannelId String?
  modRoleId          String?
  // Premium
  subscriptionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournaments  Tournament[]
  games        Game[]
  leaderboards Leaderboard[]
  members      GuildMember[]
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([discordId])
}

model GuildMember {
  id        String   @id @default(cuid())
  userId    String
  guildId   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
  @@index([guildId])
}

// ============================================================
// Games (configurables por guild)
// ============================================================

model Game {
  id        String   @id @default(cuid())
  guildId   String
  name      String   // ej: "Valorant", "Smash Ultimate"
  slug      String   // ej: "valorant"
  icon      String?
  // Settings JSON: best-of default, mapas, etc
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild        Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  tournaments  Tournament[]
  leaderboards Leaderboard[]

  @@unique([guildId, slug])
  @@index([guildId])
}

// ============================================================
// Tournaments
// ============================================================

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
  FFA
  GROUP_STAGE
}

enum FfaDirection {
  HIGHER_BETTER  // más puntaje = mejor (típico arcade/kills)
  LOWER_BETTER   // menos puntaje = mejor (typical carrera/tiempo)
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  CHECK_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentVisibility {
  PRIVATE      // solo en el guild
  PUBLIC       // listado en discovery
  UNLISTED     // accesible por link, no listado
}

enum SeedingMode {
  RANDOM        // shuffle al iniciar
  REGISTRATION  // orden de registro
  MANUAL        // admin define seeds (Fase 3+)
}

model Tournament {
  id            String   @id @default(cuid())
  guildId       String
  gameId        String?
  creatorId     String
  // Identificación
  name          String
  slug          String
  description   String?
  // Config
  format        TournamentFormat
  status        TournamentStatus    @default(DRAFT)
  visibility    TournamentVisibility @default(PRIVATE)
  maxParticipants Int      @default(32)
  bestOf        Int        @default(1)   // BO1, BO3, BO5
  teamSize      Int        @default(1)   // 1 = solo, 2+ = equipo
  seedingMode   SeedingMode @default(RANDOM)
  // FFA / Group stage config
  ffaDirection  FfaDirection? // HIGHER_BETTER (default) o LOWER_BETTER en FFA
  groupCount    Int? // cantidad de grupos en GROUP_STAGE
  advancePerGroup Int? // top N de cada grupo que pasa a playoffs
  // Timing
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  startsAt             DateTime?
  endedAt              DateTime?
  // Discord
  channelId     String?    // canal donde se anuncia
  threadId      String?    // thread del torneo
  registrationMessageId String? // mensaje con botones de registro
  voiceCategoryId String?  // categoría con los VCs de los matches
  // Bracket data (JSON serializado del bracket completo)
  bracketData   Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  guild         Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  game          Game?        @relation(fields: [gameId], references: [id], onDelete: SetNull)
  creator       User         @relation("TournamentCreator", fields: [creatorId], references: [id])
  participants  Participant[]
  matches       Match[]

  @@unique([guildId, slug])
  @@index([guildId, status])
  @@index([visibility, status])
}

// ============================================================
// Participants
// ============================================================

enum ParticipantStatus {
  REGISTERED
  CHECKED_IN
  ELIMINATED
  WINNER
  DISQUALIFIED
  WITHDRAWN
}

model Participant {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  // Para teams: nombre del team y miembros adicionales como JSON
  teamName     String?
  teammates    Json     @default("[]")
  // Estado
  status       ParticipantStatus @default(REGISTERED)
  seed         Int?
  finalRank    Int?
  // Stats
  wins         Int      @default(0)
  losses       Int      @default(0)
  // Para FFA: puntaje libre numérico que el participante reporta
  ffaScore     Decimal? @db.Decimal(12, 3)
  ffaNote      String?  // ej. "1:23:45 lap time"
  // Para GROUP_STAGE: a qué grupo pertenece (1, 2, 3, ...)
  groupNumber  Int?
  registeredAt DateTime @default(now())
  checkedInAt  DateTime?

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchesAsP1  Match[]    @relation("MatchP1")
  matchesAsP2  Match[]    @relation("MatchP2")

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

// ============================================================
// Matches
// ============================================================

enum MatchStatus {
  PENDING       // sin participantes asignados todavía
  READY         // listo para jugar
  IN_PROGRESS   // jugadores reportando
  COMPLETED
  DISPUTED      // resultados contradictorios
  CANCELLED
}

enum BracketSide {
  WINNERS
  LOSERS
  GRAND_FINAL
}

model Match {
  id           String   @id @default(cuid())
  tournamentId String
  // Posición en el bracket
  round        Int
  matchNumber  Int       // posición dentro de la ronda
  bracketSide  BracketSide @default(WINNERS)
  // Participantes
  participant1Id String?
  participant2Id String?
  winnerId       String?
  // Score
  scoreP1      Int       @default(0)
  scoreP2      Int       @default(0)
  // Estado
  status       MatchStatus @default(PENDING)
  // Avance: a qué match va el ganador / perdedor
  nextMatchId       String?  // match destino del ganador
  loserNextMatchId  String?  // match destino del perdedor (double elim)
  // Discord
  threadId        String?
  voiceChannelId  String?  // VC del match (creado al estar READY)
  // Timestamps
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  participant1 Participant? @relation("MatchP1", fields: [participant1Id], references: [id], onDelete: SetNull)
  participant2 Participant? @relation("MatchP2", fields: [participant2Id], references: [id], onDelete: SetNull)
  reports      MatchReport[]

  @@index([tournamentId, status])
  @@index([tournamentId, round])
}

// Reportes de score (cada participante reporta, el bot valida)
model MatchReport {
  id          String   @id @default(cuid())
  matchId     String
  reporterId  String   // userId del que reporta
  scoreP1     Int
  scoreP2     Int
  winnerId    String?
  evidence    String?  // URL screenshot opcional
  createdAt   DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

// ============================================================
// Leaderboards (persistentes por guild + game)
// ============================================================

model Leaderboard {
  id        String   @id @default(cuid())
  guildId   String
  gameId    String?
  name      String
  // Configuración del scoring
  config    Json     @default("{}")  // { winPoints: 3, lossPoints: 0, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild   Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  game    Game?              @relation(fields: [gameId], references: [id], onDelete: SetNull)
  entries LeaderboardEntry[]

  @@index([guildId])
}

model LeaderboardEntry {
  id            String   @id @default(cuid())
  leaderboardId String
  userId        String
  points        Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  tournamentsPlayed Int  @default(0)
  tournamentsWon    Int  @default(0)
  updatedAt     DateTime @updatedAt

  leaderboard Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, userId])
  @@index([leaderboardId, points(sort: Desc)])
}

// ============================================================
// Premium / Subscriptions
// ============================================================

enum SubscriptionTier {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Subscription {
  id                   String   @id @default(cuid())
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  guilds Guild[]
}
