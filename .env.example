# --- Database ---
# Puerto 5435 para no chocar con otros postgres locales (scalping_timescaledb, p3d_db)
DATABASE_URL="postgresql://camibot:camibot@localhost:5435/camibot?schema=public"

# --- Redis ---
# Puerto 6383 para no chocar con scalping_redis (6379), erp_redis (6380), p3d_redis (6382)
REDIS_URL="redis://localhost:6383"

# --- Discord App (https://discord.com/developers/applications) ---
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_PUBLIC_KEY=""
DISCORD_TOKEN=""

# --- Auth.js (web) ---
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3001"

# --- Stripe (Fase 4) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- App ---
NODE_ENV="development"
